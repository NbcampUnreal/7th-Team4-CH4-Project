# 이 파일이 프로젝트의 최상위 설정 파일임을 명시합니다. (상위 폴더 검색 중단)
root = true
 
# ------------------------------------------------------------------------------
# 1. 모든 파일에 적용되는 기본 설정
# ------------------------------------------------------------------------------
[*]
# [중요] 한글 주석 깨짐 및 컴파일 에러 방지 (BOM이 포함된 UTF-8 강제)
charset = utf-8-bom
 
# 윈도우(Windows) 표준 줄 바꿈 방식(CRLF) 사용
end_of_line = crlf
 
# 파일 저장 시 맨 마지막 줄에 빈 줄을 자동으로 하나 추가 (git 표준 준수)
insert_final_newline = true
 
# 코드 줄 끝에 불필요하게 붙은 공백을 저장 시 자동으로 제거
trim_trailing_whitespace = true
 
# [변경] 언리얼 공식 코딩 표준: 탭(Tab) 문자 사용 (스페이스 아님)
# 참고: https://dev.epicgames.com/documentation/ko-kr/unreal-engine/epic-cplusplus-coding-standard-for-unreal-engine
indent_style = tab
 
# 탭 크기를 4로 설정 (에디터에서 탭을 표시할 너비)
tab_width = 4
 
# ------------------------------------------------------------------------------
# 2. C++ 소스(.cpp) 및 헤더(.h) 파일 전용 설정
# ------------------------------------------------------------------------------
[*.{cpp,h,inl,hpp}]
# [변경] 언리얼 공식 코딩 표준: 탭(Tab) 문자 사용
indent_style = tab
 
# 탭 크기 4 유지
tab_width = 4
 
# ------------------------------------------------------------------------------
# 3. C# 파일 전용 설정 (빌드 스크립트: Build.cs, Target.cs 등)
# ------------------------------------------------------------------------------
[*.cs]
# C#(언리얼 빌드 툴)도 탭 사용
indent_style = tab
tab_width = 4
 
 